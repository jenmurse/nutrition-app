{
  "name": "good-measure",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --webpack -p 3006",
    "dev:start": "bash -lc 'pkill -f \"next dev\" || true; nohup npm run dev > .next-dev.log 2>&1 & echo $! > .next-dev.pid; echo started $(cat .next-dev.pid) > /dev/stderr'",
    "dev:stop": "bash -lc 'if [ -f .next-dev.pid ]; then kill \"$(cat .next-dev.pid)\" 2>/dev/null || true; rm -f .next-dev.pid; fi; pkill -f \"next dev\" || true; pkill -f \"next-server\" || true; pkill -f \"next start\" || true; sleep 1; echo stopped > /dev/stderr'",
    "dev:restart": "bash -lc 'npm run dev:stop && sleep 1 && npm run dev:start'",
    "dev:logs": "bash -lc 'tail -n +1 -F .next-dev.log 2>/dev/null || true'",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convert-units": "^2.3.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "lucide-react": "^0.564.0",
    "marked": "^17.0.1",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "prisma": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.24",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  }
}

{
  "name": "nutrition-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "dev:start": "bash -lc 'pkill -f \"next dev\" || true; nohup npm run dev > .next-dev.log 2>&1 & echo $! > .next-dev.pid; echo started $(cat .next-dev.pid) > /dev/stderr'",
    "dev:stop": "bash -lc 'if [ -f .next-dev.pid ]; then kill \"$(cat .next-dev.pid)\" 2>/dev/null || true; rm -f .next-dev.pid; fi; pkill -f \"next dev\" || true; echo stopped > /dev/stderr'",
    "dev:restart": "bash -lc 'npm run dev:stop && sleep 1 && npm run dev:start'",
    "dev:logs": "bash -lc 'tail -n +1 -F .next-dev.log 2>/dev/null || true'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "better-sqlite3": "^12.6.2",
    "convert-units": "^2.3.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "marked": "^17.0.1",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0"
  }
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Pre-populated nutrients table
model Nutrient {
  id           Int                   @id @default(autoincrement())
  name         String                @unique // e.g., "calories", "fat", "satFat"
  displayName  String                // e.g., "Calories", "Saturated Fat"
  unit         String                // e.g., "kcal", "g", "mg"
  orderIndex   Int                   // for display order

  ingredientNutrients  IngredientNutrient[]
  nutritionGoals       NutritionGoal[]
  globalNutritionGoals GlobalNutritionGoal[]
}

// Ingredients with basic info
model Ingredient {
  id           Int                   @id @default(autoincrement())
  name         String                @unique
  fdcId        String?               // USDA Food Data Central ID for lookups
  source       String                @default("custom") // "usda" or "custom"
  defaultUnit  String                @default("g") // e.g., "g", "ml", or "other" if using custom units
  customUnitName    String?          // e.g., "banana" when defaultUnit is "other"
  customUnitAmount  Float?           // e.g., 1 (meaning 1 banana is the reference)
  customUnitGrams   Float?           // e.g., 120 (meaning 1 banana = 120g)
  isMealItem   Boolean               @default(false) // If true, shows in meal plan ingredient list
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  nutrientValues    IngredientNutrient[]
  recipeIngredients RecipeIngredient[]
  mealLogs          MealLog[]
}

// Junction table: Ingredients to Nutrients (per 100g)
model IngredientNutrient {
  id            Int       @id @default(autoincrement())
  ingredientId  Int
  nutrientId    Int
  value         Float     // per 100g

  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  nutrient      Nutrient   @relation(fields: [nutrientId], references: [id], onDelete: Cascade)

  @@unique([ingredientId, nutrientId])
}

// Recipes containing multiple ingredients
model Recipe {
  id            Int       @id @default(autoincrement())
  name          String
  servingSize   Float     // number of servings
  servingUnit   String    @default("servings") // "servings", "g", "ml", etc.
  instructions  String    // markdown format
  sourceApp     String?   // e.g., "Pestle"
  isComplete    Boolean   @default(true) // whether all ingredients are specified
  tags          String    @default("") // comma-separated recipe categories: breakfast, lunch, dinner, snack, side, dessert, beverage
  prepTime      Int?      // minutes
  cookTime      Int?      // minutes
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  image         String?   // optional image URL

  // AI analysis — stored results, run once on save/import
  optimizeAnalysis  String?   // JSON: optimization suggestions
  mealPrepAnalysis  String?   // JSON: meal prep candidacy + notes
  analysisModel     String?   // model used, e.g. "claude-sonnet-4-20250514"
  analyzedAt        DateTime? // when analysis was last run

  ingredients RecipeIngredient[]
  mealLogs    MealLog[]
}

// Junction table: Recipes to Ingredients
model RecipeIngredient {
  id                Int       @id @default(autoincrement())
  recipeId          Int
  ingredientId      Int
  quantity          Float     // amount in specified unit
  unit              String    // e.g., "cup", "tsp", "g", "ml"
  conversionGrams   Float?    // cached gram equivalent for quick lookup
  notes             String?   // optional notes for this ingredient

  recipe            Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
}

// Household persons (e.g. Jen, Garth)
model Person {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  color     String   @default("#6B9E7B")
  createdAt DateTime @default(now())

  mealPlans            MealPlan[]
  globalNutritionGoals GlobalNutritionGoal[]
}

// Weekly meal plans
model MealPlan {
  id              Int       @id @default(autoincrement())
  weekStartDate   DateTime
  personId        Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  person          Person?         @relation(fields: [personId], references: [id])
  mealLogs        MealLog[]
  nutritionGoals  NutritionGoal[]
}

// Daily meal entries (breakfast, lunch, dinner, snacks)
// Can contain either a Recipe OR a standalone Ingredient (for snacks, single items, etc.)
model MealLog {
  id         Int       @id @default(autoincrement())
  mealPlanId Int
  date       DateTime  // specific date in the week
  mealType   String    // "breakfast", "lunch", "dinner", "snack"
  recipeId   Int?      // recipe-based meal (null if ingredient-based)
  ingredientId Int?    // ingredient-based meal (null if recipe-based)
  quantity   Float?    // quantity for ingredient-based meals
  unit       String?   // unit for ingredient-based meals (e.g., "g", "ml", "banana")
  servings   Float     @default(1) // servings for recipe-based meals
  notes      String?   // optional notes
  position   Int       @default(0) // display order within a day
  createdAt  DateTime  @default(now())

  mealPlan   MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe     Recipe?   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
}

// Daily nutrient goals (low/high targets)
model NutritionGoal {
  id           Int       @id @default(autoincrement())
  mealPlanId   Int
  nutrientId   Int
  lowGoal      Float?    // minimum daily intake (null = no min)
  highGoal     Float?    // maximum daily intake (null = no max)

  mealPlan     MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  nutrient     Nutrient  @relation(fields: [nutrientId], references: [id], onDelete: Cascade)

  @@unique([mealPlanId, nutrientId])
}

// Key-value store for app-level settings (API key, provider, etc.)
model SystemSetting {
  key   String @id
  value String
}

// Token usage tracking per AI call
model ApiUsageLog {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  provider     String   @default("anthropic")
  model        String   @default("")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
}

// USDA search result cache (7-day TTL)
model UsdaSearchCache {
  id        Int      @id @default(autoincrement())
  query     String   @unique // lowercase-normalized search term
  response  Json     // full filtered USDA response
  createdAt DateTime @default(now())
}

// USDA food detail cache (no expiry — USDA data is stable)
model UsdaFoodCache {
  id        Int      @id @default(autoincrement())
  fdcId     String   @unique
  response  Json     // full USDA food detail response
  createdAt DateTime @default(now())
}

// Global nutrient goals (used by settings page defaults)
model GlobalNutritionGoal {
  id         Int      @id @default(autoincrement())
  nutrientId Int
  personId   Int?
  lowGoal    Float?
  highGoal   Float?

  nutrient   Nutrient @relation(fields: [nutrientId], references: [id], onDelete: Cascade)
  person     Person?  @relation(fields: [personId], references: [id])

  @@unique([nutrientId, personId])
}
